# pyenv
#   For a library or package, you might want to ignore these files since the Python version is individual or project-specific.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, lock files should be placed under source control.
#   However, if you feel strongly about it, feel free to uncomment the following lines.
# PIPENV_VENV_IN_PROJECT=1
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# pdm.lock
#   pdm stores project-wide configurations in .pdm-python and .pdm-build
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/python-extern
